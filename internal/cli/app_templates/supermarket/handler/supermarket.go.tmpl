package handlers

import (
	"net/http"

	"github.com/puppe1990/cais/pkg/cais"
	"github.com/puppe1990/cais/pkg/cais/httpx"
	"github.com/puppe1990/cais/pkg/cais/meta"
)

// SupermarketPageData carries layout chrome shared with the React prototype.
type SupermarketPageData struct {
	meta.Site
	Scans      []PriceScanView
	Markets    []MarketView
	Products   []ProductView
	Badges     []BadgeView
	Leaders    []LeaderView
}

type PriceScanView struct {
	ID              int
	ProductName     string
	SupermarketName string
	Price           string
	TimeAgo         string
	Contributor     string
	Level           int
	ConfirmedCount  int
	Verified        bool
	Outdated        bool
}

type MarketView struct {
	Name     string
	Address  string
	Distance string
	Offers   int
	BestDeal string
}

type ProductView struct {
	Name     string
	Barcode  string
	Category string
	AvgPrice string
}

type BadgeView struct {
	ID          string
	Name        string
	Description string
	Unlocked    bool
	Icon        string
}

type LeaderView struct {
	Name   string
	Points int
	Rank   int
	Level  int
	IsYou  bool
}

type SupermarketHandler struct {
	renderer *cais.Renderer
	site     meta.Site
	cfg      cais.Config
}

func NewSupermarketHandler(renderer *cais.Renderer, site meta.Site, cfg cais.Config) *SupermarketHandler {
	return &SupermarketHandler{renderer: renderer, site: site, cfg: cfg}
}

func (h *SupermarketHandler) base(r *http.Request) SupermarketPageData {
	site := meta.ForRequest(h.site, r)
	site.UserLevel = 3
	site.UserPoints = 420
	site.UserRank = 12
	return SupermarketPageData{
		Site:       site,
		Scans:      demoScans(),
		Markets:    demoMarkets(),
		Products:   demoProducts(),
		Badges:     demoBadges(),
		Leaders:    demoLeaders(),
	}
}

func (h *SupermarketHandler) Scan(w http.ResponseWriter, r *http.Request) {
	data := h.base(r)
	data.ActiveNav = "scan"
	httpx.RenderOrError(w, h.renderer, "base", "scan", data, h.cfg)
}

func (h *SupermarketHandler) Map(w http.ResponseWriter, r *http.Request) {
	data := h.base(r)
	data.ActiveNav = "map"
	httpx.RenderOrError(w, h.renderer, "base", "map", data, h.cfg)
}

func (h *SupermarketHandler) Feed(w http.ResponseWriter, r *http.Request) {
	data := h.base(r)
	data.ActiveNav = "feed"
	httpx.RenderOrError(w, h.renderer, "base", "feed", data, h.cfg)
}

func (h *SupermarketHandler) Achievements(w http.ResponseWriter, r *http.Request) {
	data := h.base(r)
	data.ActiveNav = "achievements"
	httpx.RenderOrError(w, h.renderer, "base", "achievements", data, h.cfg)
}

func (h *SupermarketHandler) NFCe(w http.ResponseWriter, r *http.Request) {
	data := h.base(r)
	data.ActiveNav = "nfce"
	httpx.RenderOrError(w, h.renderer, "base", "nfce", data, h.cfg)
}

